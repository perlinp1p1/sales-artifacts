<div class="progress" id="progress"></div>

<div class="topbar">
  <div class="topbar-inner">
    <span class="brand">JamesEdition · Integrations 101</span>
    <nav>
      <a href="#basics">Basics</a>
      <a href="#glossary">Glossary</a>
      <a href="#types">The 3 Types</a>
      <a href="#decide">Decision Tree</a>
      <a href="#cheatsheet">CRM Cheatsheet</a>
      <a href="#live">Live Cases</a>
      <a href="#resources">Resources</a>
    </nav>
  </div>
</div>

<main>

<!-- HERO -->
<div class="hero">
  <div class="eyebrow">Sales Team Workshop</div>
  <h1>Integrations 101</h1>
  <p class="hero-lead">How a listing travels from a client's CRM onto JamesEdition, what the acronyms mean, and exactly what you do in each scenario.</p>
  <div class="hero-meta">Thursday, June 11, 2026 · 9:00 CET</div>
</div>

<!-- BASICS -->
<section id="basics">
  <h2>The Big Idea</h2>
  <p class="sub">One concept, then the moving parts.</p>
  <p class="lead-p">An <b>integration</b> is an automated connection that pulls a client's listings, photos and agent data out of their CRM and publishes it on JamesEdition. They change it once, in their own system. It syncs to us on its own.</p>

  <div class="stats">
    <div class="stat"><div class="n">241+</div><div class="l">Feed adapters built</div></div>
    <div class="stat"><div class="n">40+</div><div class="l">CRM systems connected</div></div>
    <div class="stat"><div class="n">3×</div><div class="l">Daily feed runs (00:00 / 08:00 / 16:00 UTC)</div></div>
    <div class="stat"><div class="n">2</div><div class="l">Integration engineers (Arthur &amp; Ivan)</div></div>
  </div>

  <h3>How a listing gets online</h3>
  <div class="flow">
    <div class="flow-step"><div class="si">Step 1</div><div class="st">Client CRM</div><div class="ss">Apimo, OnOffice…</div></div>
    <div class="flow-step"><div class="si">Step 2</div><div class="st">Export</div><div class="ss">XML / API / FTP</div></div>
    <div class="flow-step"><div class="si">Step 3</div><div class="st">JE pulls it</div><div class="ss">3× daily</div></div>
    <div class="flow-step"><div class="si">Step 4</div><div class="st">Parse &amp; validate</div><div class="ss">Map, moderate</div></div>
    <div class="flow-step"><div class="si">Step 5</div><div class="st">Live on JE</div><div class="ss">Published</div></div>
  </div>

  <h3>Four rules that explain most problems</h3>
  <ul class="rules">
    <li><span class="marker">01</span><span><b>One office = one feed.</b> An office can't hold two feeds. Switch CRM, and the old feed is replaced.</span></li>
    <li><span class="marker">02</span><span><b>The feed is the source of truth.</b> If a listing leaves the feed, it deactivates on JE. By design.</span></li>
    <li><span class="marker">03</span><span><b>Moderation still applies.</b> A clean import can still be rejected (price too low, images too small, wrong category).</span></li>
    <li><span class="marker">04</span><span><b>Price floor.</b> $490,000 for sales, $2,000/week for rentals. Below that is auto-rejected.</span></li>
  </ul>
</section>

<!-- GLOSSARY -->
<section id="glossary">
  <h2>The Glossary</h2>
  <p class="sub">Tap a card to flip it. Test yourself before the cases.</p>
  <div class="gloss" id="gloss"></div>
</section>

<!-- 3 TYPES + GAME -->
<section id="types">
  <h2>The 3 Types of Integration</h2>
  <p class="sub">This is the whole job. Every client falls into one of three buckets.</p>
  <div class="legend">
    <span class="chip auto">Automated — client activates from their CRM. Zero work for you.</span>
    <span class="chip self">Self-service — you set up the feed in the Admin Panel.</span>
    <span class="chip ticket">Ticket — the integration team configures it.</span>
  </div>

  <h3 style="margin-top:var(--space-l)">Quiz: which bucket?</h3>
  <div class="game">
    <div class="game-head">
      <span style="font-size:13px;font-weight:600;">Sort the CRM</span>
      <span class="score">Score <b id="score">0</b> / <span id="answered">0</span></span>
    </div>
    <div class="game-body">
      <div class="game-prompt">A client tells you they use…</div>
      <div class="game-crm" id="crm">—</div>
      <div class="game-region" id="region"></div>
      <div class="game-choices">
        <button class="choice" data-c="auto">Automated<span class="key">activate from CRM</span></button>
        <button class="choice" data-c="self">Self-service<span class="key">you set up the feed</span></button>
        <button class="choice" data-c="ticket">Ticket<span class="key">integration team</span></button>
      </div>
      <div class="game-feedback" id="feedback"></div>
    </div>
    <div class="game-foot">
      <button class="btn btn--ghost" id="next" style="display:none;">Next →</button>
      <button class="btn btn--teal" id="start">Start the quiz</button>
    </div>
  </div>
</section>

<!-- DECISION TREE -->
<section id="decide">
  <h2>What Do I Do When…?</h2>
  <p class="sub">Walk the tree. It ends on your exact next action.</p>
  <div class="tree" id="tree"></div>
  <div class="callout">
    <b>Golden rule:</b> before anything, check the
    <a href="https://www.notion.so/jamesedition/8767d23d-54e5-4a81-a76c-f273124d87e4" target="_blank">Notion Integrations Knowledge Base</a>.
    There's a page for every CRM we've ever touched, with step-by-step instructions.
  </div>
</section>

<!-- CHEATSHEET -->
<section id="cheatsheet">
  <h2>CRM Cheatsheet</h2>
  <p class="sub">Filter to what you need. This is your day-to-day reference.</p>
  <div class="filters" id="filters">
    <button class="filter active" data-f="all">All</button>
    <button class="filter" data-f="auto">Automated</button>
    <button class="filter" data-f="self">Self-service</button>
    <button class="filter" data-f="ticket">Ticket</button>
  </div>
  <table>
    <thead><tr><th>CRM / Format</th><th>Region</th><th>Type</th><th>What to do</th></tr></thead>
    <tbody id="cheatbody"></tbody>
  </table>
</section>

<!-- LIVE CASES -->
<section id="live">
  <h2>Live Cases</h2>
  <p class="sub">We solve these together on screen. Tap to reveal the scenario, then talk me through your steps before I show the answer.</p>
  <div class="cases" id="cases"></div>
</section>

<!-- MYTHS -->
<section id="myths">
  <h2>Spot the Mistake</h2>
  <p class="sub">Real ones from the team. Guess the right move, then tap to check.</p>
  <div class="myths" id="myths"></div>
</section>

<!-- RESOURCES -->
<section id="resources">
  <h2>Resources</h2>
  <p class="sub">Where to look and who to ask.</p>
  <div class="res-grid">
    <div class="res">
      <h3>Where to look</h3>
      <table>
        <tr><td>Notion KB</td><td>CRM pages, step-by-step guides, partner contacts</td></tr>
        <tr><td>Admin → Feeds</td><td>Configs, FTP accounts, run history, error logs</td></tr>
        <tr><td>Shortcut → Integrations</td><td>Create tickets for the integration team</td></tr>
        <tr><td>#integrations</td><td>General questions and updates</td></tr>
        <tr><td>#crm-integrations</td><td>CRM-specific questions, ask Vishal</td></tr>
      </table>
    </div>
    <div class="res">
      <h3>Who to ask</h3>
      <table>
        <tr><td>Vishal Maan</td><td>CRM partnerships, new integrations (crm@jamesedition.com)</td></tr>
        <tr><td>Nadia</td><td>Feed ops, self-service, Admin Panel help</td></tr>
        <tr><td>Arthur &amp; Ivan</td><td>Integration engineering, complex feeds, lead delivery</td></tr>
        <tr><td>Timur Zaitsev</td><td>Supply strategy, automation, process calls</td></tr>
      </table>
    </div>
  </div>

  <div class="update" style="margin-top:var(--space-l)">
    <span class="tag">New · June 10, 2026</span>
    <h3 style="margin-top:8px;font-family:var(--font-serif);font-weight:400;font-size:20px;text-transform:none;letter-spacing:0;color:var(--je-black);">Seller Account listings page</h3>
    <ul>
      <li><b>Published / Rejected / Deleted</b> tabs separate active, moderated-out, and removed listings.</li>
      <li><b>Sellers can restore deleted listings themselves</b> — no support ticket needed.</li>
      <li>Search by listing reference works across all tabs; reference is copyable from the card.</li>
    </ul>
    <p class="note">Fewer "my listing disappeared" tickets. Point clients to their Seller Account first.</p>
  </div>

  <div class="callout" style="margin-top:var(--space-l)">
    <b>When in doubt:</b> check Notion, then ask in #integrations. The fastest way to lose a client is wrong integration advice. The fastest way to annoy the integration team is a ticket for something you could do yourself.
  </div>
</section>

</main>

<script>
/* ---------- progress + nav highlight ---------- */
const prog=document.getElementById('progress');
const links=[...document.querySelectorAll('.topbar nav a')];
const secs=links.map(a=>document.querySelector(a.getAttribute('href')));
window.addEventListener('scroll',()=>{
  const h=document.documentElement.scrollHeight-document.documentElement.clientHeight;
  prog.style.width=(scrollY/h*100)+'%';
  let cur=secs.length-1;
  for(let i=0;i<secs.length;i++){if(secs[i].getBoundingClientRect().top>120){cur=i-1;break;}}
  links.forEach((l,i)=>l.classList.toggle('active',i===cur));
});

/* ---------- glossary ---------- */
const glossary=[
  ['API','Application Programming Interface','A structured way for two systems to talk over the internet — like a waiter taking your order and bringing the food. Many CRMs expose one for JE to connect to.'],
  ['FTP / SFTP','File Transfer Protocol','A shared cloud folder. The client drops their listing file in, JE picks it up. SFTP is the encrypted version.'],
  ['XML','Extensible Markup Language','Tag-based text format, like HTML. Most real estate feeds use it. e.g. <price>500000</price>'],
  ['JSON','JavaScript Object Notation','A more modern data format used by API CRMs like Apimo and Reapit. Looks like {"price":500000}.'],
  ['CSV','Comma-Separated Values','A simple spreadsheet-style file. One line per listing. Less common than XML for property feeds.'],
  ['CRM','Customer Relationship Management','The software an agency uses to manage listings and clients. Apimo, OnOffice, Hektor, Casafari…'],
  ['Feed','Data Feed','The file or API endpoint holding the client\'s listings. JE pulls it on a schedule. One office = one feed.'],
  ['MLS','Multiple Listing Service','A shared agent database, mainly US/Canada. We connect via Constellation1 and Trestle. Agents don\'t touch it.'],
  ['OpenImmo','German XML standard','Used across DACH CRMs (OnOffice, Justimmo, PropStack). Common for German, Austrian, Swiss clients.'],
  ['Webhook','Reverse API call','The CRM pushes data to JE when something changes, instead of JE pulling. Used in some lead flows.'],
  ['RETS','Real Estate Transaction Standard','Older protocol for MLS data in North America, being replaced by RESO Web API. You\'ll hear it from US clients.'],
  ['Feed Run','Import cycle','Each time JE downloads and processes a feed. Status and listing counts show in the Admin Panel.']
];
document.getElementById('gloss').innerHTML=glossary.map(g=>`
  <div class="flip">
    <div class="flip-inner">
      <div class="flip-face flip-front"><div class="term">${g[0]}</div><div class="full">${g[1]}</div><div class="tap">Tap to flip</div></div>
      <div class="flip-face flip-back"><div class="def">${g[2]}</div></div>
    </div>
  </div>`).join('');
document.querySelectorAll('.flip').forEach(f=>f.onclick=()=>f.classList.toggle('flipped'));

/* ---------- sort game ---------- */
const pool=[
  ['Apimo','France · Monaco','auto'],['Hektor / La Boite Immo','France','auto'],
  ['Orisha / AC3','France','auto'],['eGO Real Estate','Portugal','auto'],
  ['iList','Greece','auto'],['Justimmo','Austria','auto'],
  ['Sooprema','Belgium · France · Spain','self'],['Kyero','Spain · Portugal','self'],
  ['Inmoweb','Spain','self'],['Property Finder','UAE','self'],
  ['JamesEdition XML','Global','self'],['Adaptimmo','France','self'],
  ['OnOffice','Germany','ticket'],['Immomig','Switzerland','ticket'],
  ['Reapit','UK · UAE','ticket'],['Constellation / MLS','USA · Canada','ticket'],
  ['Casafari','Portugal · Spain','ticket'],['PropStack','Germany','ticket']
];
const names={auto:'Automated',self:'Self-service',ticket:'Ticket'};
const because={auto:'the client activates JE from inside their CRM — no work for you.',
  self:'you grab the feed URL and set it up in the Admin Panel yourself.',
  ticket:'it needs custom config, so the integration team handles it via a ticket.'};
let queue=[],idx=0,score=0,answered=0;
const elCrm=document.getElementById('crm'),elReg=document.getElementById('region'),
  elFb=document.getElementById('feedback'),elScore=document.getElementById('score'),
  elAns=document.getElementById('answered'),elNext=document.getElementById('next'),
  elStart=document.getElementById('start'),choices=[...document.querySelectorAll('.choice')];
function shuffle(a){return a.map(x=>[Math.random(),x]).sort((p,q)=>p[0]-q[0]).map(x=>x[1]);}
function load(){
  const q=queue[idx];elCrm.textContent=q[0];elReg.textContent=q[1];
  elFb.textContent='';elFb.className='game-feedback';
  choices.forEach(c=>{c.disabled=false;c.className='choice';});
  elNext.style.display='none';
}
function answer(c){
  const q=queue[idx];answered++;
  choices.forEach(b=>{
    b.disabled=true;
    if(b.dataset.c===q[2])b.classList.add('correct');
    if(b.dataset.c===c&&c!==q[2])b.classList.add('wrong');
  });
  if(c===q[2]){score++;elFb.textContent='Correct — '+because[q[2]];elFb.className='game-feedback ok';}
  else{elFb.textContent='It\'s '+names[q[2]]+': '+because[q[2]];elFb.className='game-feedback no';}
  elScore.textContent=score;elAns.textContent=answered;
  elNext.style.display='inline-flex';
  elNext.textContent=idx<queue.length-1?'Next →':'Restart';
}
choices.forEach(c=>c.onclick=()=>answer(c.dataset.c));
elStart.onclick=()=>{queue=shuffle(pool);idx=0;score=0;answered=0;elScore.textContent=0;elAns.textContent=0;elStart.style.display='none';load();};
elNext.onclick=()=>{if(idx<queue.length-1){idx++;load();}else{queue=shuffle(pool);idx=0;score=0;answered=0;elScore.textContent=0;elAns.textContent=0;load();}};

/* ---------- decision tree ---------- */
const tree=document.getElementById('tree');
const nodes={
  q1:{q:'Does the client already have a feed running on JE?',hint:'Admin Panel → Office → Feeds. Is there an active config?',
    opts:[['Yes, and it works','r_ok'],['No feed yet','q2']]},
  q2:{q:'What CRM does the client use?',hint:'Ask: "What software do you use to manage your listings?"',
    opts:[['An automated partner','r_auto'],['A self-service format','r_self'],['They want to upload a file (FTP)','r_ftp'],['Unsupported / complex / new','r_ticket']]},
};
const results={
  r_ok:['No action needed.','Listings sync automatically. If they report missing or wrong data, go to the troubleshooting case.'],
  r_auto:['Tell the client to activate JamesEdition from inside their CRM.','Office and listings are created automatically. If a manual office already exists, raise a merge ticket. Partners: Apimo, Hektor, Orisha, eGO, iList, Justimmo.'],
  r_self:['Get the feed URL and set it up yourself.','<code>Admin → Office → Feeds → Add feed → select format → paste URL → save.</code> Formats: JE XML, Kyero, Sooprema, Property Finder, Inmoba, Inmoweb, Adaptimmo.'],
  r_ftp:['Create an FTP account, then add the feed.','<code>Admin → Feeds → FTP Accounts → New</code>, send credentials to the client, then add the feed using the FTP URL. Save credentials in 1Password.'],
  r_ticket:['Create a Shortcut ticket in the Integrations workflow.','Include client name, office ID, CRM name, feed URL or credentials, and plan level. For: OnOffice multi-office, Immomig, Reapit, MLS, any new CRM.'],
};
function renderNode(key){
  const n=nodes[key];
  tree.innerHTML=`<div class="tree-q">${n.q}</div><div class="tree-hint">${n.hint}</div>
    <div class="tree-opts">${n.opts.map((o,i)=>`<button class="btn ${i===0&&key==='q1'?'btn--teal':'btn--ghost'}" data-go="${o[1]}">${o[0]}</button>`).join('')}</div>
    <div class="tree-result" id="treeres"></div>`;
  tree.querySelectorAll('[data-go]').forEach(b=>b.onclick=()=>go(b.dataset.go));
}
function go(target){
  if(nodes[target]){renderNode(target);return;}
  const r=results[target];
  const res=document.getElementById('treeres');
  res.innerHTML=`<div class="rt">${r[0]}</div><div class="rb">${r[1]}</div>
    <div style="margin-top:14px;"><button class="btn btn--ghost" id="treereset">Start over</button></div>`;
  res.classList.add('show');
  document.getElementById('treereset').onclick=()=>renderNode('q1');
}
renderNode('q1');

/* ---------- cheatsheet ---------- */
const sheet=[
  ['Apimo','France · Monaco','auto','Client activates from the Apimo dashboard. Office auto-created.'],
  ['Hektor / La Boite Immo','France','auto','Client activates from Hektor. ~8,000 agencies reachable.'],
  ['Orisha / AC3','France','auto','Client activates from Orisha. ~16,000 agencies reachable.'],
  ['eGO Real Estate','Portugal','auto','Client emails eGO support. Same-day gateway activation.'],
  ['iList / Fortunet Hellas','Greece','auto','Client activates JE inside iList. Auto-created within 24h.'],
  ['Justimmo','Austria','auto','Multi-office feed. ~1,000 sellers, ~8,000 listings.'],
  ['Sooprema','Belgium · France · Spain','self','Get the XML feed URL, add it in the Admin Panel.'],
  ['Kyero format','Spain · Portugal','self','Get the feed URL, add it (Kyero format).'],
  ['Inmoweb','Spain','self','Get the feed URL, set up in Admin.'],
  ['Adaptimmo','France','self','Get the feed URL, set up in Admin.'],
  ['Property Finder / MyCRM','UAE','self','Get the feed URL, add it in Admin.'],
  ['JamesEdition XML','Global','self','Client builds to our spec, you add the URL.'],
  ['OnOffice','Germany','ticket','Multi-office FTP. Client activates, ticket to link the office.'],
  ['PropStack','Germany','ticket','Client requests migration. Ticket for setup.'],
  ['Immomig','Switzerland','ticket','Client emails Immomig support, then you raise a ticket.'],
  ['Reapit / Street','UK · UAE','ticket','API-based. Ticket with the customer tenant code.'],
  ['Constellation / MLS','USA · Canada','ticket','MLS data, handled centrally. Contact Vishal.'],
  ['Casafari','Portugal · Spain','ticket','API integration. Ticket for setup.'],
];
const body=document.getElementById('cheatbody');
function renderSheet(f){
  body.innerHTML=sheet.filter(r=>f==='all'||r[2]===f).map(r=>
    `<tr><td><b>${r[0]}</b></td><td>${r[1]}</td><td><span class="dot ${r[2]}">${names[r[2]]}</span></td><td>${r[3]}</td></tr>`).join('');
}
renderSheet('all');
document.querySelectorAll('.filter').forEach(b=>b.onclick=()=>{
  document.querySelectorAll('.filter').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');renderSheet(b.dataset.f);
});

/* ---------- live cases (scenario only — solved live) ---------- */
const cases=[
  ['Case 1','Client uses Sooprema and wants to publish','A Spanish agency you just closed says they run Sooprema. They ask you to set up the integration. What do you do?'],
  ['Case 2','Client uses Apimo / eGO / Hektor','A French agency on Apimo wants on JE. A Portuguese client on eGO asks the same. What\'s the move for each?'],
  ['Case 3','Client wants to upload XML via FTP','"My developer built an XML feed in your format. Where do I upload it?" Walk through setting up FTP and the feed.'],
  ['Case 4','Listings are not updating','A paying client updated prices in their CRM, but JE still shows the old ones. What do you check, in order?'],
  ['Case 5','Client is switching CRMs','A client on Casafari is moving to PropStack. What happens to their listings, and what do you set up?'],
  ['Case 6','A CRM you\'ve never heard of','One client names Immomig, another OnOffice, a third a CRM no one recognises. How do you handle each?'],
  ['Case 7','Feed images not showing','A client says some listings have no photos, or the wrong ones. How do you find out whose side the problem is on?'],
];
document.getElementById('cases').innerHTML=cases.map(c=>
  `<div class="case"><div class="cn">${c[0]}</div><div class="ct">${c[1]}</div><div class="reveal-hint">Tap to reveal scenario</div><div class="scenario">${c[2]}</div></div>`).join('');
document.querySelectorAll('.case').forEach(c=>c.onclick=()=>c.classList.toggle('open'));

/* ---------- myths ---------- */
const myths=[
  ['You should open a Shortcut ticket for a Sooprema feed.','<span class="right">No.</span> Sooprema is self-service. Get the feed URL and set it up in the Admin Panel yourself.'],
  ['Create the JE office manually for an Apimo / Hektor client.','<span class="right">No.</span> The integration creates the office automatically. A manual one first means a messy merge ticket.'],
  ['When a client says a feed is broken, tell them we\'ll fix it.','<span class="right">Check first.</span> About 70% of "feed not updating" issues are on the client\'s CRM side — expired credentials, export off, unchanged file.'],
  ['After setting up a feed, the job is done.','<span class="right">Not yet.</span> Always check the first run: Admin → Office → Feeds → see results. Feeds can fail silently.'],
];
document.getElementById('myths').innerHTML=myths.map(m=>
  `<div class="myth"><div class="q"><span>${m[0]}</span><span class="toggle">+</span></div><div class="a">${m[1]}</div></div>`).join('');
document.querySelectorAll('.myth').forEach(m=>m.onclick=()=>m.classList.toggle('open'));
</script>
</body>
</html>
