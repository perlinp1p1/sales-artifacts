<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Integrations 101 — JamesEdition Sales Workshop</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Prata&display=swap" rel="stylesheet">
<style>
:root{
  --je-teal-deep:#006C75; --je-teal:#0ebab4; --je-teal-deep-hover:#19818A;
  --je-green:#178475; --je-gold-dark:#b9a16f; --je-gold-light:#dfd5c0;
  --je-warning:#E79E32;
  --je-black:#151515; --je-mid-gray:#606060; --je-light-gray:#878787;
  --je-muted-gray:#ADADAD; --je-border:#E0E0E0; --je-divider:#ececec;
  --je-off-white:#F5F5F5; --je-near-white:#F7F7F7; --je-white:#FFFFFF;
  --je-error:#E63232;
  --space-xs:16px; --space-s:24px; --space-m:32px; --space-l:48px; --space-xl:64px;
  --font-sans:'Inter',Arial,sans-serif; --font-serif:'Prata',serif;
}
@media (max-width:767px){:root{--space-xs:8px;--space-s:16px;--space-m:24px;--space-l:32px;--space-xl:48px;}}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--font-sans);font-size:16px;line-height:1.6;color:var(--je-black);background:var(--je-white);-webkit-font-smoothing:antialiased;}

/* progress + topbar */
.progress{position:fixed;top:0;left:0;height:2px;width:0;background:var(--je-teal-deep);z-index:200;transition:width .15s;}
.topbar{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--je-divider);}
.topbar-inner{max-width:1000px;margin:0 auto;display:flex;align-items:center;gap:20px;padding:12px 24px;overflow-x:auto;}
.topbar .brand{font-weight:600;font-size:13px;letter-spacing:.5px;white-space:nowrap;}
.topbar nav{display:flex;gap:18px;}
.topbar nav a{font-size:12px;color:var(--je-light-gray);white-space:nowrap;border-bottom:2px solid transparent;padding:4px 0;}
.topbar nav a:hover,.topbar nav a.active{color:var(--je-teal-deep);border-bottom-color:var(--je-teal-deep);}

main{max-width:1000px;margin:0 auto;padding:0 24px 120px;}

/* hero */
.hero{padding:var(--space-xl) 0 var(--space-l);border-bottom:1px solid var(--je-divider);margin-bottom:var(--space-xl);}
.eyebrow{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--je-teal-deep);font-weight:600;margin-bottom:var(--space-s);}
h1{font-family:var(--font-serif);font-weight:400;font-size:54px;line-height:1.05;letter-spacing:-.01em;margin-bottom:var(--space-s);}
.hero-lead{font-size:19px;color:var(--je-mid-gray);max-width:640px;line-height:1.5;}
.hero-meta{margin-top:var(--space-m);font-size:12px;letter-spacing:1px;text-transform:uppercase;color:var(--je-light-gray);}

/* sections */
section{margin-bottom:var(--space-xl);scroll-margin-top:72px;}
h2{font-family:var(--font-serif);font-weight:400;font-size:32px;line-height:1.15;margin-bottom:8px;}
.sub{font-size:15px;color:var(--je-light-gray);margin-bottom:var(--space-m);}
h3{font-size:18px;font-weight:600;margin-bottom:12px;}
p{margin-bottom:14px;}
.lead-p{font-size:18px;color:var(--je-mid-gray);max-width:680px;}

/* stat row */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--je-divider);border:1px solid var(--je-divider);margin:var(--space-m) 0;}
.stat{background:var(--je-white);padding:24px 20px;}
.stat .n{font-family:var(--font-serif);font-size:34px;line-height:1;color:var(--je-teal-deep);}
.stat .l{font-size:12px;color:var(--je-light-gray);margin-top:8px;line-height:1.4;}
@media(max-width:767px){.stats{grid-template-columns:repeat(2,1fr);}}

/* flow */
.flow{display:flex;align-items:stretch;gap:0;margin:var(--space-m) 0;flex-wrap:wrap;}
.flow-step{flex:1;min-width:130px;padding:20px 16px;border:1px solid var(--je-divider);border-right:none;background:var(--je-white);}
.flow-step:last-child{border-right:1px solid var(--je-divider);}
.flow-step .si{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--je-teal-deep);font-weight:600;margin-bottom:6px;}
.flow-step .st{font-weight:600;font-size:15px;margin-bottom:2px;}
.flow-step .ss{font-size:12px;color:var(--je-light-gray);}
@media(max-width:767px){.flow-step{flex-basis:100%;border-right:1px solid var(--je-divider);border-bottom:none;}.flow-step:last-child{border-bottom:1px solid var(--je-divider);}}

/* key rules */
.rules{list-style:none;border-top:1px solid var(--je-divider);}
.rules li{padding:16px 0;border-bottom:1px solid var(--je-divider);display:flex;gap:14px;font-size:15px;}
.rules li b{display:block;}
.rules .marker{color:var(--je-teal-deep);font-weight:600;flex-shrink:0;}

/* glossary flip cards */
.gloss{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-top:var(--space-s);}
.flip{height:120px;perspective:1000px;cursor:pointer;}
.flip-inner{position:relative;width:100%;height:100%;transition:transform .5s;transform-style:preserve-3d;}
.flip.flipped .flip-inner{transform:rotateY(180deg);}
.flip-face{position:absolute;inset:0;backface-visibility:hidden;border:1px solid var(--je-border);border-radius:4px;padding:16px;display:flex;flex-direction:column;justify-content:center;}
.flip-front{background:var(--je-near-white);}
.flip-front .term{font-weight:600;font-size:18px;color:var(--je-black);}
.flip-front .full{font-size:12px;color:var(--je-light-gray);margin-top:4px;}
.flip-front .tap{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--je-teal-deep);margin-top:auto;}
.flip-back{background:var(--je-black);color:var(--je-white);transform:rotateY(180deg);}
.flip-back .def{font-size:12.5px;line-height:1.45;overflow:auto;}

/* sort game */
.game{border:1px solid var(--je-border);border-radius:4px;overflow:hidden;}
.game-head{background:var(--je-near-white);padding:16px 20px;border-bottom:1px solid var(--je-divider);display:flex;justify-content:space-between;align-items:center;}
.game-head .score{font-size:13px;color:var(--je-mid-gray);}
.game-head .score b{color:var(--je-teal-deep);}
.game-body{padding:var(--space-m) var(--space-s);text-align:center;}
.game-prompt{font-size:13px;color:var(--je-light-gray);letter-spacing:1px;text-transform:uppercase;margin-bottom:12px;}
.game-crm{font-family:var(--font-serif);font-size:40px;margin-bottom:6px;}
.game-region{font-size:13px;color:var(--je-light-gray);margin-bottom:var(--space-m);}
.game-choices{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.choice{padding:14px 22px;border-radius:4px;border:1px solid var(--je-border);background:var(--je-white);font-family:var(--font-sans);font-size:14px;font-weight:500;cursor:pointer;transition:all .2s;}
.choice:hover:not(:disabled){border-color:var(--je-black);}
.choice:disabled{cursor:default;}
.choice .key{display:block;font-size:11px;color:var(--je-light-gray);margin-top:3px;font-weight:400;}
.choice.correct{background:var(--je-teal-deep);color:#fff;border-color:var(--je-teal-deep);}
.choice.correct .key{color:rgba(255,255,255,.7);}
.choice.wrong{background:#fff;border-color:var(--je-error);color:var(--je-error);}
.game-feedback{min-height:24px;margin-top:var(--space-s);font-size:14px;font-weight:500;}
.game-feedback.ok{color:var(--je-teal-deep);}
.game-feedback.no{color:var(--je-error);}
.game-foot{padding:14px 20px;border-top:1px solid var(--je-divider);text-align:center;}

/* buttons */
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;font-family:var(--font-sans);font-size:14px;font-weight:500;border-radius:4px;border:1px solid transparent;cursor:pointer;transition:all .2s;text-decoration:none;}
.btn--teal{background:var(--je-teal-deep);color:#fff;}
.btn--teal:hover{background:var(--je-teal-deep-hover);color:#fff;}
.btn--ghost{background:#fff;color:var(--je-black);border-color:var(--je-border);}
.btn--ghost:hover{border-color:var(--je-black);}

/* decision tree */
.tree{border:1px solid var(--je-border);border-radius:4px;padding:var(--space-m);}
.tree-q{font-size:20px;font-weight:600;margin-bottom:6px;}
.tree-hint{font-size:14px;color:var(--je-light-gray);margin-bottom:var(--space-s);}
.tree-opts{display:flex;flex-wrap:wrap;gap:12px;}
.tree-result{margin-top:var(--space-s);padding:20px;border-left:3px solid var(--je-teal-deep);background:var(--je-near-white);display:none;}
.tree-result.show{display:block;}
.tree-result .rt{font-weight:600;margin-bottom:6px;}
.tree-result .rb{font-size:14px;color:var(--je-mid-gray);line-height:1.5;}
.tree-result code{font-family:'Courier New',monospace;font-size:13px;background:var(--je-white);padding:2px 6px;border:1px solid var(--je-divider);border-radius:3px;}

/* type legend chips */
.legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:var(--space-s);}
.chip{font-size:12px;font-weight:600;padding:5px 12px;border-radius:30px;display:inline-flex;align-items:center;gap:7px;}
.chip::before{content:'';width:8px;height:8px;border-radius:50%;}
.chip.auto{background:rgba(0,108,117,.08);color:var(--je-teal-deep);}
.chip.auto::before{background:var(--je-teal-deep);}
.chip.self{background:rgba(23,132,117,.08);color:var(--je-green);}
.chip.self::before{background:var(--je-green);}
.chip.ticket{background:rgba(231,158,50,.12);color:#9a6a14;}
.chip.ticket::before{background:var(--je-warning);}

/* cheatsheet */
.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:var(--space-s);}
.filter{font-size:12px;font-weight:500;padding:7px 14px;border-radius:30px;border:1px solid var(--je-border);background:#fff;cursor:pointer;transition:all .2s;}
.filter.active{background:var(--je-black);color:#fff;border-color:var(--je-black);}
table{width:100%;border-collapse:collapse;font-size:14px;}
th{text-align:left;font-weight:500;font-size:12px;letter-spacing:.5px;text-transform:uppercase;color:var(--je-light-gray);border-bottom:1px solid var(--je-divider);padding:12px 14px;}
td{padding:12px 14px;border-bottom:1px solid var(--je-divider);}
tbody tr:hover{background:var(--je-near-white);}
.dot{display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:500;}
.dot::before{content:'';width:8px;height:8px;border-radius:50%;}
.dot.auto{color:var(--je-teal-deep);}.dot.auto::before{background:var(--je-teal-deep);}
.dot.self{color:var(--je-green);}.dot.self::before{background:var(--je-green);}
.dot.ticket{color:#9a6a14;}.dot.ticket::before{background:var(--je-warning);}

/* live exercise cards */
.cases{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-top:var(--space-s);}
@media(max-width:767px){.cases{grid-template-columns:1fr;}}
.case{border:1px solid var(--je-border);border-radius:4px;padding:20px;cursor:pointer;transition:all .2s;background:#fff;}
.case:hover{box-shadow:var(--shadow-subtle,0 3px 13px rgba(107,107,107,.2));}
.case .cn{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--je-light-gray);margin-bottom:8px;}
.case .ct{font-weight:600;font-size:16px;margin-bottom:10px;line-height:1.3;}
.case .scenario{font-size:14px;color:var(--je-mid-gray);line-height:1.5;display:none;margin-top:10px;padding-top:12px;border-top:1px solid var(--je-divider);}
.case.open .scenario{display:block;}
.case .reveal-hint{font-size:12px;color:var(--je-teal-deep);font-weight:500;}
.case.open .reveal-hint{display:none;}

/* myth reveal */
.myths{border-top:1px solid var(--je-divider);margin-top:var(--space-s);}
.myth{border-bottom:1px solid var(--je-divider);padding:18px 0;cursor:pointer;}
.myth .q{font-weight:600;font-size:15px;display:flex;justify-content:space-between;gap:16px;}
.myth .q .toggle{color:var(--je-teal-deep);flex-shrink:0;transition:transform .2s;}
.myth.open .q .toggle{transform:rotate(45deg);}
.myth .a{font-size:14px;color:var(--je-mid-gray);line-height:1.5;max-height:0;overflow:hidden;transition:max-height .25s;}
.myth.open .a{max-height:200px;margin-top:10px;}
.myth .a .right{color:var(--je-green);font-weight:500;}

/* callout + resources */
.callout{background:var(--je-near-white);border-left:3px solid var(--je-teal-deep);padding:20px 24px;margin-top:var(--space-s);font-size:15px;line-height:1.5;}
.res-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-s);margin-top:var(--space-s);}
@media(max-width:767px){.res-grid{grid-template-columns:1fr;}}
.res h3{font-size:14px;letter-spacing:.5px;text-transform:uppercase;color:var(--je-light-gray);font-weight:600;}
.res table td{font-size:13.5px;}
.res table td:first-child{font-weight:600;white-space:nowrap;}
.note{font-size:13px;color:var(--je-light-gray);margin-top:8px;}

.update{border:1px solid var(--je-divider);border-radius:4px;padding:24px;background:var(--je-near-white);}
.update .tag{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--je-gold-dark);font-weight:600;}
.update ul{list-style:none;margin-top:12px;}
.update li{padding:8px 0;border-bottom:1px solid var(--je-divider);font-size:14px;padding-left:20px;position:relative;}
.update li:last-child{border-bottom:none;}
.update li::before{content:'';position:absolute;left:0;top:15px;width:6px;height:6px;border-radius:50%;background:var(--je-teal-deep);}

@media print{.topbar,.progress{display:none;}.flip-inner{transform:none!important;}}
</style>
</head>
